/* button.wxss - 通用按钮样式 */

/* 基础按钮 */
.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-md, 12rpx);
  font-weight: bold;
  transition: all var(--transition-fast, 0.2s);
  border: none;
  position: relative;
}

.btn-hover {
  transform: scale(0.98);
  opacity: 0.9;
}

.btn-disabled {
  opacity: 0.5;
  pointer-events: none;
}

/* 尺寸 */
.btn-small {
  padding: var(--space-xs, 8rpx) var(--space-sm, 16rpx);
  font-size: var(--text-sm, 24rpx);
}

.btn-medium {
  padding: var(--space-sm, 16rpx) var(--space-md, 24rpx);
  font-size: var(--text-base, 28rpx);
}

.btn-large {
  padding: var(--space-md, 24rpx) var(--space-lg, 32rpx);
  font-size: var(--text-lg, 32rpx);
}

/* 类型 - 实心 */
.btn-primary {
  background: var(--primary-color, #d4a84c);
  color: var(--text-color-inverse, #1a1410);
}

.btn-secondary {
  background: var(--secondary-color, #a67c52);
  color: var(--text-color, #f5e6d3);
}

.btn-success {
  background: var(--color-success, #6b9b2d);
  color: white;
}

.btn-warning {
  background: var(--color-warning, #f39c12);
  color: white;
}

.btn-error {
  background: var(--color-error, #e8483a);
  color: white;
}

/* 类型 - 镂空 */
.btn-outline.btn-primary {
  background: transparent;
  border: 2rpx solid var(--primary-color, #d4a84c);
  color: var(--primary-color, #d4a84c);
}

.btn-outline.btn-secondary {
  background: transparent;
  border: 2rpx solid var(--secondary-color, #a67c52);
  color: var(--secondary-color, #a67c52);
}

/* 加载动画 */
.btn-loading {
  width: 24rpx;
  height: 24rpx;
  border: 3rpx solid currentColor;
  border-top-color: transparent;
  border-radius: 50%;
  animation: btn-spin 0.8s linear infinite;
  margin-right: var(--space-xs, 8rpx);
}

@keyframes btn-spin {
  to {
    transform: rotate(360deg);
  }
}

.btn-text {
  white-space: nowrap;
}
