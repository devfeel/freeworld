/* 装备槽位组件样式 */
.equipment-slot {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, rgba(0, 0, 0, 0.3) 0%, rgba(0, 0, 0, 0.5) 100%);
  border: 1px solid var(--border-color-light);
  border-radius: var(--radius-md);
  overflow: hidden;
  transition: all var(--transition-fast);
}

/* 尺寸变体 */
.equipment-slot.small {
  width: 48px;
  height: 48px;
}

.equipment-slot.medium {
  width: 64px;
  height: 64px;
}

.equipment-slot.large {
  width: 80px;
  height: 80px;
}

/* 空槽位样式 */
.equipment-slot.empty {
  border-style: dashed;
  border-color: var(--border-color);
}

.equipment-slot.empty .slot-label {
  position: absolute;
  top: 2px;
  left: 2px;
  font-size: var(--text-xs);
  color: var(--text-color-muted);
}

.equipment-slot.empty .slot-icon {
  font-size: var(--text-xl);
  opacity: 0.3;
}

/* 已装备样式 */
.equipment-slot.filled {
  background: linear-gradient(135deg, var(--panel-bg) 0%, var(--panel-bg-dark) 100%);
  border-color: var(--primary-color);
  box-shadow: var(--inset-shadow-sm);
}

.equipment-slot.filled:active {
  transform: scale(0.95);
  box-shadow: var(--glow-primary);
}

.equipment-icon {
  width: 60%;
  height: 60%;
  object-fit: contain;
}

.equipment-emoji {
  font-size: var(--text-2xl);
  filter: drop-shadow(0 2px 4px rgba(0, 0, 0, 0.5));
}

/* 强化等级标记 */
.enhance-level {
  position: absolute;
  top: 2px;
  right: 2px;
  padding: 0 4px;
  background: linear-gradient(135deg, var(--color-success) 0%, var(--color-success-dark) 100%);
  border-radius: var(--radius-sm);
  font-size: var(--text-xs);
  font-weight: bold;
  color: white;
  z-index: 2;
}

/* 稀有度光晕 */
.rarity-glow {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
  opacity: 0.3;
  border-radius: var(--radius-md);
}

.rarity-glow.common { box-shadow: inset 0 0 8px rgba(158, 158, 158, 0.5); }
.rarity-glow.uncommon { box-shadow: inset 0 0 8px rgba(30, 255, 0, 0.5); }
.rarity-glow.rare { box-shadow: inset 0 0 8px rgba(0, 112, 221, 0.5); }
.rarity-glow.epic { box-shadow: inset 0 0 10px rgba(163, 53, 238, 0.6); }
.rarity-glow.legendary {
  box-shadow: inset 0 0 12px rgba(255, 128, 0, 0.7);
  animation: legendary-glow 2s infinite;
}

@keyframes legendary-glow {
  0%, 100% { box-shadow: inset 0 0 12px rgba(255, 128, 0, 0.5); }
  50% { box-shadow: inset 0 0 20px rgba(255, 128, 0, 0.8); }
}

.rarity-glow.mythic { box-shadow: inset 0 0 12px rgba(231, 76, 60, 0.7); }
.rarity-glow.divine { box-shadow: inset 0 0 15px rgba(255, 215, 0, 0.8); }

/* 套装标记 */
.set-badge {
  position: absolute;
  bottom: 2px;
  left: 2px;
  width: 16px;
  height: 16px;
  background: linear-gradient(135deg, var(--color-loot) 0%, var(--color-loot-dark) 100%);
  border-radius: 50%;
  font-size: var(--text-xs);
  font-weight: bold;
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 2;
}

/* 新物品动画 */
.equipment-slot.new-item {
  animation: newItemGlow 1.5s ease-in-out infinite;
}

@keyframes newItemGlow {
  0%, 100% {
    box-shadow: 0 0 5px var(--primary-color), inset 0 0 5px var(--primary-color);
  }
  50% {
    box-shadow: 0 0 20px var(--primary-color), inset 0 0 10px var(--primary-color);
  }
}

/* 槽位名称 */
.slot-name {
  position: absolute;
  bottom: -20px;
  font-size: var(--text-xs);
  color: var(--text-color-secondary);
  white-space: nowrap;
}
