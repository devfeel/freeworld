/* 进度条组件样式 */
.progress-wrapper {
  position: relative;
  width: 100%;
  height: 12px;
  background: var(--bg-color-dark);
  border: 1px solid var(--border-color);
  border-radius: var(--radius-full);
  overflow: hidden;
  box-shadow: var(--inset-shadow-sm);
}

.progress-fill {
  height: 100%;
  border-radius: var(--radius-full);
  transition: width 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
  overflow: hidden;
}

.progress-fill::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 50%;
  background: linear-gradient(to bottom, rgba(255, 255, 255, 0.3), transparent);
  border-radius: var(--radius-full) var(--radius-full) 0 0;
}

.progress-text {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  font-size: var(--text-xs);
  font-weight: bold;
  color: var(--text-color);
  text-shadow: 0 1px 2px rgba(0, 0, 0, 0.8);
  z-index: 1;
}

/* 不同类型 */
.hp-bar .progress-fill {
  background: linear-gradient(to right, var(--color-error), var(--color-error-dark));
}

.mp-bar .progress-fill {
  background: linear-gradient(to right, var(--color-info), var(--color-info-dark));
}

.exp-bar .progress-fill {
  background: linear-gradient(to right, var(--primary-color), var(--primary-dark));
}

.stamina-bar .progress-fill {
  background: linear-gradient(to right, var(--color-success), var(--color-success-dark));
}

.custom-bar .progress-fill {
  background: linear-gradient(to right, var(--secondary-color), var(--secondary-dark));
}
