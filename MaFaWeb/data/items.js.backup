// 获取道具数据
function getItem(id) {
  return ITEMS[id]
}

// 获取稀有度标签类名
function getRarityClass(rarity) {
  const rarityMap = {
    'common': 'tag-common',
    'uncommon': 'tag-rare',
    'rare': 'tag-rare',
    'epic': 'tag-epic',
    'legendary': 'tag-legendary'
  }
  return rarityMap[rarity] || 'tag-common'
}

// 获取稀有度中文名
function getRarityName(rarity) {
  const rarityMap = {
    'common': '普通',
    'uncommon': '优秀',
    'rare': '稀有',
    'epic': '史诗',
    'legendary': '传说'
  }
  return rarityMap[rarity] || '普通'
}

// 获取商城可购买物品
function getShopItems(category = 'all') {
  return Object.values(ITEMS).filter(item =>
    item.type === 'potion' && (
      category === 'all' ||
      (category === 'hp' && item.subType === 'hp') ||
      (category === 'mp' && item.subType === 'mp') ||
      (category === 'dual' && item.subType === 'dual')
    )
  )
}

module.exports = {
  ITEMS,
  getItem,
  getRarityClass,
  getRarityName,
  getShopItems
}
