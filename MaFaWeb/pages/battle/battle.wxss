/* 战斗界面样式 */

/* 敌人信息面板 */
.enemy-info-panel {
  text-align: center;
  padding: 8px;
  margin-bottom: 5px;
  position: relative;
  z-index: 1;
}

.enemy-name {
  font-size: 16px;
  font-weight: bold;
  color: var(--primary-color);
  margin-bottom: 5px;
  display: block;
}

/* 战斗画面 */
.battle-canvas {
  width: 100%;
  height: 300rpx;
  margin: 10px 0;
  border: 2px solid var(--border-color);
  border-radius: 4px;
  background-color: #1a0f0a;
  display: block;
  position: relative;
  z-index: 1;
}

/* 英雄信息面板 */
.hero-info-panel {
  text-align: center;
  padding: 8px;
  margin-top: 5px;
  position: relative;
  z-index: 1;
}

.hero-name {
  font-size: 16px;
  font-weight: bold;
  color: var(--primary-color);
  margin-bottom: 5px;
  display: block;
}

/* 小型进度条 */
.progress-bar.small {
  height: 12px;
}

/* 战斗日志 */
.battle-logs {
  max-height: 200rpx;
  margin-top: 10px;
  position: relative;
  z-index: 1;
}

.logs-container {
  height: 150rpx;
}

.log-item {
  padding: 3px 0;
  border-bottom: 1px solid rgba(255, 255, 255, 0.1);
}

/* 控制面板 */
.control-panel {
  margin-top: 10px;
  position: relative;
  z-index: 1;
}

.turn-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 15px;
  padding: 10px;
  background-color: rgba(0, 0, 0, 0.3);
  border-radius: 4px;
}

.auto-battle-toggle {
  display: flex;
  align-items: center;
  gap: 10px;
}

.auto-battle-info {
  text-align: center;
  padding: 10px;
  background-color: rgba(0, 0, 0, 0.3);
  border-radius: 4px;
}

.skills {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-bottom: 10px;
}

.skill-btn {
  flex: 1;
  min-width: 100px;
  font-size: 12px;
  padding: 8px;
}

/* 新技能槽样式 */
.skills-row {
  display: flex;
  justify-content: space-between;
  gap: 8px;
  margin-bottom: 10px;
}

.skill-slot {
  position: relative;
  width: 64px;
  height: 64px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, rgba(45, 35, 25, 0.8) 0%, rgba(30, 20, 15, 0.9) 100%);
  border: 2px solid rgba(212, 175, 55, 0.3);
  border-radius: 8px;
  overflow: hidden;
}

.skill-slot.filled {
  background: linear-gradient(135deg, rgba(212, 175, 55, 0.15) 0%, rgba(30, 20, 15, 0.8) 100%);
  border-color: rgba(212, 175, 55, 0.5);
}

.skill-slot.empty {
  background: rgba(0, 0, 0, 0.3);
  border-color: rgba(255, 255, 255, 0.1);
}

.skill-slot .skill-icon {
  font-size: 24px;
  margin-bottom: 2px;
}

.skill-slot .skill-name-small {
  font-size: 9px;
  color: #d4af37;
  text-align: center;
}

.skill-slot .empty-text {
  font-size: 20px;
  color: rgba(255, 255, 255, 0.3);
}

.skill-slot .skill-cost {
  position: absolute;
  top: 2px;
  right: 2px;
  background: rgba(52, 152, 219, 0.8);
  border-radius: 4px;
  padding: 1px 4px;
}

.skill-slot .cost-text {
  font-size: 8px;
  color: #fff;
}

.skill-slot .cooldown-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.7);
  display: flex;
  align-items: center;
  justify-content: center;
}

.skill-slot .cooldown-text {
  font-size: 20px;
  font-weight: bold;
  color: #e74c3c;
}

.skill-slot .no-mp-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.5);
}

.other-actions {
  display: flex;
  gap: 10px;
}

.other-actions .btn {
  flex: 1;
}

/* 战斗结果浮层 */
.battle-result-overlay {
  position: fixed !important;
  top: 0 !important;
  left: 0 !important;
  right: 0 !important;
  bottom: 0 !important;
  width: 100vw !important;
  height: 100vh !important;
  background-color: rgba(0, 0, 0, 0.98);
  display: flex !important;
  align-items: center;
  justify-content: center;
  z-index: 99999999 !important;
  padding: 20px;
  padding-bottom: 40px;
  box-sizing: border-box;
}

.battle-result-modal {
  background-color: var(--panel-bg);
  border: 3px solid var(--primary-color);
  border-radius: 8px;
  padding: 25px;
  min-width: 280px;
  max-width: 380px;
  max-height: calc(100vh - 100px);
  overflow-y: auto;
  box-shadow: 0 0 30px rgba(0, 0, 0, 0.9);
  animation: fadeIn 0.3s ease;
  position: relative;
  z-index: 100000000 !important;
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: scale(0.9);
  }
  to {
    opacity: 1;
    transform: scale(1);
  }
}

.battle-result-modal .panel-title {
  font-size: 24px;
  margin-bottom: 20px;
}

.rewards {
  display: flex;
  flex-direction: column;
  gap: 12px;
  padding: 20px 0;
}

.rewards text {
  display: block;
  text-align: center;
  color: var(--primary-color);
  font-size: 16px;
  padding: 8px;
  background-color: rgba(0, 0, 0, 0.3);
  border-radius: 4px;
}

/* 结果按钮 */
.result-actions {
  display: flex;
  flex-direction: column;
  gap: 10px;
  margin-top: 20px;
}

.result-actions .btn {
  width: 100%;
  font-size: 16px;
  padding: 12px;
}

