/* 战斗界面样式 */

/* 敌人信息面板 */
.enemy-info-panel {
  text-align: center;
  padding: 8px;
  margin-bottom: 5px;
  position: relative;
  z-index: 1;
}

.enemy-name {
  font-size: 16px;
  font-weight: bold;
  color: var(--primary-color);
  margin-bottom: 5px;
  display: block;
}

/* 战斗画面 */
.battle-canvas {
  width: 100%;
  height: 400rpx;
  margin: 10px 0;
  border: 2px solid var(--border-color);
  border-radius: 4px;
  background-color: #1a0f0a;
  display: block;
  position: relative;
  z-index: 1;
}

/* 英雄信息面板 */
.hero-info-panel {
  text-align: center;
  padding: 8px;
  margin-top: 5px;
  position: relative;
  z-index: 1;
}

.hero-name {
  font-size: 16px;
  font-weight: bold;
  color: var(--primary-color);
  margin-bottom: 5px;
  display: block;
}

/* 小型进度条 */
.progress-bar.small {
  height: 12px;
}

/* 战斗日志 */
.battle-logs {
  max-height: 240rpx;
  margin-top: 10px;
  position: relative;
  z-index: 1;
}

.battle-logs .panel-title {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.turn-counter {
  font-size: 12px;
  color: #888;
  background: rgba(0, 0, 0, 0.3);
  padding: 2px 8px;
  border-radius: 10px;
}

.logs-container {
  height: 180rpx;
}

.log-item {
  display: flex;
  align-items: flex-start;
  padding: 6px 0;
  border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  font-size: 13px;
  line-height: 1.4;
  animation: logEnter 0.3s ease;
}

.log-item.new-entry {
  animation: logHighlight 1s ease;
}

@keyframes logEnter {
  from {
    opacity: 0;
    transform: translateX(-10px);
  }
  to {
    opacity: 1;
    transform: translateX(0);
  }
}

@keyframes logHighlight {
  0%, 100% {
    background: transparent;
  }
  30%, 70% {
    background: rgba(212, 175, 55, 0.1);
  }
}

.log-icon {
  width: 20px;
  height: 20px;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 6px;
  font-size: 14px;
  flex-shrink: 0;
}

.log-content {
  flex: 1;
  display: flex;
  flex-wrap: wrap;
  align-items: center;
}

.log-actor {
  font-weight: bold;
  margin-right: 4px;
  padding: 1px 4px;
  border-radius: 3px;
  font-size: 11px;
}

.log-actor.hero {
  color: #4caf50;
  background: rgba(76, 175, 80, 0.15);
}

.log-actor.enemy {
  color: #f44336;
  background: rgba(244, 67, 54, 0.15);
}

.log-actor.system {
  color: #9e9e9e;
  background: rgba(158, 158, 158, 0.15);
}

.log-message {
  color: #e0e0e0;
  flex: 1;
}

.log-badges {
  display: flex;
  gap: 4px;
  margin-left: 4px;
}

.badge {
  font-size: 10px;
  padding: 1px 4px;
  border-radius: 3px;
  font-weight: bold;
}

.badge.critical {
  background: linear-gradient(135deg, #ff6b6b, #ee5a24);
  color: #fff;
  animation: badgePulse 1s ease infinite;
}

.badge.dodge {
  background: linear-gradient(135deg, #74b9ff, #0984e3);
  color: #fff;
}

.badge.heal {
  background: linear-gradient(135deg, #55efc4, #00b894);
  color: #fff;
}

.badge.buff {
  background: linear-gradient(135deg, #a29bfe, #6c5ce7);
  color: #fff;
}

.badge.debuff {
  background: linear-gradient(135deg, #fd79a8, #e84393);
  color: #fff;
}

@keyframes badgePulse {
  0%, 100% {
    transform: scale(1);
  }
  50% {
    transform: scale(1.1);
  }
}

.log-time {
  font-size: 10px;
  color: #666;
  margin-left: 4px;
  flex-shrink: 0;
}

/* 日志类型样式 */
.log-item.damage {
  border-left: 2px solid #ff6b6b;
}

.log-item.heal {
  border-left: 2px solid #55efc4;
}

.log-item.buff {
  border-left: 2px solid #a29bfe;
}

.log-item.debuff {
  border-left: 2px solid #fd79a8;
}

.log-item.dodge {
  border-left: 2px solid #74b9ff;
}

.log-item.system {
  border-left: 2px solid #9e9e9e;
}

/* 控制面板 */
.control-panel {
  margin-top: 10px;
  position: relative;
  z-index: 1;
}

.turn-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 15px;
  padding: 10px;
  background-color: rgba(0, 0, 0, 0.3);
  border-radius: 4px;
}

.auto-battle-toggle {
  display: flex;
  align-items: center;
  gap: 10px;
}

.auto-battle-info {
  text-align: center;
  padding: 10px;
  background-color: rgba(0, 0, 0, 0.3);
  border-radius: 4px;
}

.skills {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-bottom: 10px;
}

.skill-btn {
  flex: 1;
  min-width: 100px;
  font-size: 12px;
  padding: 8px;
}

/* 新技能槽样式 */
.skills-row {
  display: flex;
  justify-content: space-between;
  gap: 8px;
  margin-bottom: 10px;
}

.skill-slot {
  position: relative;
  width: 64px;
  height: 64px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, rgba(45, 35, 25, 0.8) 0%, rgba(30, 20, 15, 0.9) 100%);
  border: 2px solid rgba(212, 175, 55, 0.3);
  border-radius: 8px;
  overflow: hidden;
}

.skill-slot.filled {
  background: linear-gradient(135deg, rgba(212, 175, 55, 0.15) 0%, rgba(30, 20, 15, 0.8) 100%);
  border-color: rgba(212, 175, 55, 0.5);
}

.skill-slot.empty {
  background: rgba(0, 0, 0, 0.3);
  border-color: rgba(255, 255, 255, 0.1);
}

.skill-slot .skill-icon {
  font-size: 24px;
  margin-bottom: 2px;
}

.skill-slot .skill-name-small {
  font-size: 9px;
  color: #d4af37;
  text-align: center;
}

.skill-slot .empty-text {
  font-size: 20px;
  color: rgba(255, 255, 255, 0.3);
}

.skill-slot .skill-cost {
  position: absolute;
  top: 2px;
  right: 2px;
  background: rgba(52, 152, 219, 0.8);
  border-radius: 4px;
  padding: 1px 4px;
}

.skill-slot .cost-text {
  font-size: 8px;
  color: #fff;
}

.skill-slot .cooldown-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.7);
  display: flex;
  align-items: center;
  justify-content: center;
}

.skill-slot .cooldown-text {
  font-size: 20px;
  font-weight: bold;
  color: #e74c3c;
}

.skill-slot .no-mp-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.5);
}

.other-actions {
  display: flex;
  gap: 10px;
}

.other-actions .btn {
  flex: 1;
}

/* 战斗结果浮层 */
.battle-result-overlay {
  position: fixed !important;
  top: 0 !important;
  left: 0 !important;
  right: 0 !important;
  bottom: 0 !important;
  width: 100vw !important;
  height: 100vh !important;
  background-color: rgba(0, 0, 0, 0.98);
  display: flex !important;
  align-items: center;
  justify-content: center;
  z-index: 99999999 !important;
  padding: 20px;
  padding-bottom: 40px;
  box-sizing: border-box;
}

.battle-result-modal {
  background-color: var(--panel-bg);
  border: 3px solid var(--primary-color);
  border-radius: 8px;
  padding: 25px;
  min-width: 280px;
  max-width: 380px;
  max-height: calc(100vh - 100px);
  overflow-y: auto;
  box-shadow: 0 0 30px rgba(0, 0, 0, 0.9);
  animation: fadeIn 0.3s ease;
  position: relative;
  z-index: 100000000 !important;
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: scale(0.9);
  }
  to {
    opacity: 1;
    transform: scale(1);
  }
}

.battle-result-modal .panel-title {
  font-size: 24px;
  margin-bottom: 20px;
}

.rewards {
  display: flex;
  flex-direction: column;
  gap: 12px;
  padding: 20px 0;
}

.rewards text {
  display: block;
  text-align: center;
  color: var(--primary-color);
  font-size: 16px;
  padding: 8px;
  background-color: rgba(0, 0, 0, 0.3);
  border-radius: 4px;
}

/* 结果按钮 */
.result-actions {
  display: flex;
  flex-direction: column;
  gap: 10px;
  margin-top: 20px;
}

.result-actions .btn {
  width: 100%;
  font-size: 16px;
  padding: 12px;
}

/* 状态效果显示 */
.status-effects {
  display: flex;
  flex-wrap: wrap;
  gap: 4px;
  margin-top: 8px;
  justify-content: center;
}

.status-effects.enemy-status {
  justify-content: center;
}

.status-effects.hero-status {
  justify-content: flex-start;
  margin-top: 10px;
  padding-left: 5px;
}

.status-icon {
  position: relative;
  width: 28px;
  height: 28px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, rgba(45, 35, 25, 0.9) 0%, rgba(30, 20, 15, 0.95) 100%);
  border-radius: 6px;
  font-size: 16px;
  border: 2px solid;
  animation: statusPulse 2s ease-in-out infinite;
}

/* Buff 类型 - 绿色边框 */
.status-icon.buff {
  border-color: #4caf50;
  box-shadow: 0 0 8px rgba(76, 175, 80, 0.4);
}

/* Debuff 类型 - 红色边框 */
.status-icon.debuff {
  border-color: #f44336;
  box-shadow: 0 0 8px rgba(244, 67, 54, 0.4);
}

/* 中性效果 - 蓝色边框 */
.status-icon.neutral {
  border-color: #2196f3;
  box-shadow: 0 0 8px rgba(33, 150, 243, 0.4);
}

.status-duration {
  position: absolute;
  bottom: -2px;
  right: -2px;
  min-width: 14px;
  height: 14px;
  background: rgba(0, 0, 0, 0.8);
  border-radius: 7px;
  font-size: 9px;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 3px;
  font-weight: bold;
}

@keyframes statusPulse {
  0%, 100% {
    transform: scale(1);
    opacity: 1;
  }
  50% {
    transform: scale(1.05);
    opacity: 0.9;
  }
}

/* 状态效果进入动画 */
.status-icon {
  animation: statusEnter 0.3s ease, statusPulse 2s ease-in-out infinite 0.3s;
}

@keyframes statusEnter {
  0% {
    transform: scale(0) rotate(-180deg);
    opacity: 0;
  }
  70% {
    transform: scale(1.2) rotate(10deg);
  }
  100% {
    transform: scale(1) rotate(0deg);
    opacity: 1;
  }
}

/* 敌人血条包装器 */
.enemy-hp-bar-wrapper {
  width: 70%;
  margin: 0 auto;
  max-width: 300px;
}

/* 英雄血条和魔法条在一行显示 */
.hero-bars {
  width: 100%;
  padding: 0 10px;
  box-sizing: border-box;
}

.bar-row.combined {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  gap: 12px;
}

.hp-bar-col,
.mp-bar-col {
  display: flex;
  align-items: center;
  flex: 1;
  gap: 4px;
  min-width: 0;
}

.bar-icon {
  font-size: 14px;
  flex-shrink: 0;
}

