/* 地下城详情页样式 */

/* 地图信息 */
.map-info {
  padding: 15px;
}

.map-header {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 10px;
}

.map-icon {
  font-size: 48px;
  width: 70px;
  height: 70px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, rgba(0, 0, 0, 0.3) 0%, rgba(0, 0, 0, 0.1) 100%);
  border-radius: 8px;
  border: 2px solid var(--border-color);
}

.map-title {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.map-name {
  font-size: 22px;
  font-weight: bold;
  color: var(--primary-color);
}

.map-atmosphere {
  font-size: 13px;
  color: var(--secondary-color);
  font-style: italic;
}

.map-desc {
  font-size: 13px;
  color: var(--text-color);
  line-height: 1.5;
  padding: 10px;
  background: rgba(0, 0, 0, 0.2);
  border-radius: 4px;
}

/* 基本信息 */
.basic-info {
  padding: 12px 15px;
}

.info-row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 10px;
}

.info-row:last-child {
  margin-bottom: 0;
}

.info-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4px;
}

.info-label {
  font-size: 12px;
  color: var(--secondary-color);
}

.info-value {
  font-size: 16px;
  font-weight: bold;
  color: var(--primary-color);
}

.info-value.ok {
  color: var(--success-color);
}

.info-value.no {
  color: var(--danger-color);
}

.info-value.completed {
  color: var(--success-color);
}

.info-value.defeated {
  color: var(--success-color);
}

.info-value.pending {
  color: var(--danger-color);
}

/* 区块标题 */
.section-title {
  font-size: 16px;
  font-weight: bold;
  color: var(--primary-color);
  margin-bottom: 12px;
  display: block;
}

/* 怪物列表 */
.monster-section {
  padding: 15px;
}

.monster-list {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.monster-item {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 8px 10px;
  background: rgba(0, 0, 0, 0.2);
  border: 1px solid var(--border-color);
  border-radius: 4px;
}

.monster-icon {
  font-size: 24px;
  width: 36px;
  text-align: center;
}

.monster-detail {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.monster-name {
  font-size: 14px;
  font-weight: bold;
  color: var(--text-color);
}

.monster-stats {
  display: flex;
  gap: 10px;
  color: var(--secondary-color);
}

/* BOSS信息 */
.boss-section {
  padding: 15px;
}

.boss-section.defeated {
  opacity: 0.7;
}

.boss-card {
  background: linear-gradient(135deg, rgba(232, 72, 58, 0.15) 0%, rgba(0, 0, 0, 0.3) 100%);
  border: 2px solid #e8483a;
  border-radius: 8px;
  padding: 15px;
}

.boss-section.defeated .boss-card {
  background: linear-gradient(135deg, rgba(107, 155, 45, 0.15) 0%, rgba(0, 0, 0, 0.3) 100%);
  border-color: var(--success-color);
}

.boss-header {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 12px;
}

.boss-icon {
  font-size: 36px;
}

.boss-title {
  flex: 1;
}

.boss-name {
  font-size: 18px;
  font-weight: bold;
  color: #e8483a;
  display: block;
}

.boss-section.defeated .boss-name {
  color: var(--success-color);
}

.boss-stats {
  display: flex;
  justify-content: space-around;
  margin-bottom: 12px;
  padding: 10px;
  background: rgba(0, 0, 0, 0.3);
  border-radius: 4px;
}

.boss-stat {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4px;
}

.stat-value {
  font-size: 16px;
  font-weight: bold;
  color: var(--primary-color);
}

.boss-reward {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 4px;
}

.reward-text {
  font-size: 14px;
  color: #ffd700;
  font-weight: bold;
}

/* 底部操作栏 */
.action-bar {
  display: flex;
  gap: 10px;
  padding: 15px;
  background: var(--panel-bg);
  border-top: 2px solid var(--border-color);
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
}

.action-bar .btn {
  flex: 1;
  padding: 12px 10px;
  font-size: 14px;
}

/* 探索模态框 */
.explore-modal-overlay {
  position: fixed !important;
  top: 0 !important;
  left: 0 !important;
  right: 0 !important;
  bottom: 0 !important;
  width: 100vw !important;
  height: 100vh !important;
  background-color: rgba(0, 0, 0, 0.98);
  display: flex !important;
  align-items: center;
  justify-content: center;
  z-index: 2147483647 !important;
  padding: 20px;
  box-sizing: border-box;
}

.explore-modal {
  background-color: var(--panel-bg);
  border: 3px solid var(--primary-color);
  border-radius: 8px;
  padding: 25px;
  min-width: 280px;
  max-width: 380px;
  box-shadow: 0 0 30px rgba(212, 168, 76, 0.4);
  animation: fadeIn 0.3s ease;
  position: relative;
  z-index: 2147483648 !important;
}

.explore-modal .panel-title {
  color: #ffd700;
  text-shadow: 0 0 5px rgba(255, 215, 0, 0.5);
  text-align: center;
  font-size: 20px;
  margin-bottom: 15px;
}

.explore-info {
  text-align: center;
  padding: 15px 0;
}

.explore-modal .actions {
  display: flex;
  flex-direction: column;
  gap: 10px;
  margin-top: 20px;
}

.explore-modal .actions .btn {
  width: 100%;
}

/* 探索结果浮层样式 */
.explore-result-overlay {
  position: fixed !important;
  top: 0 !important;
  left: 0 !important;
  right: 0 !important;
  bottom: 0 !important;
  width: 100vw !important;
  height: 100vh !important;
  background-color: rgba(0, 0, 0, 0.98);
  display: flex !important;
  align-items: center;
  justify-content: center;
  z-index: 2147483650 !important;
  padding: 20px;
  box-sizing: border-box;
}

.explore-result-modal {
  background-color: var(--panel-bg);
  border: 3px solid var(--primary-color);
  border-radius: 8px;
  padding: 25px;
  min-width: 280px;
  max-width: 380px;
  max-height: 70vh;
  overflow-y: auto;
  box-shadow: 0 0 30px rgba(0, 0, 0, 0.9);
  animation: fadeIn 0.3s ease;
  position: relative;
  z-index: 2147483651 !important;
}

.monster-info {
  text-align: center;
  padding: 15px 0;
}

.monster-info .monster-name {
  font-size: 18px;
  font-weight: bold;
  color: var(--danger-color);
  display: block;
  margin-bottom: 10px;
}

.explore-event {
  text-align: center;
  padding: 20px;
  color: var(--secondary-color);
}

.result-actions {
  display: flex;
  flex-direction: column;
  gap: 10px;
  margin-top: 20px;
}

.result-actions .btn {
  width: 100%;
}

/* 宝箱样式 */
.chest-info {
  text-align: center;
  padding: 15px 0;
}

.chest-icon {
  font-size: 48px;
  display: block;
  margin-bottom: 10px;
  animation: chestShake 0.5s ease-in-out;
}

@keyframes chestShake {
  0%, 100% { transform: rotate(0deg); }
  25% { transform: rotate(-5deg); }
  75% { transform: rotate(5deg); }
}

.chest-rewards {
  display: flex;
  flex-direction: column;
  gap: 8px;
  padding: 10px;
  background: rgba(0, 0, 0, 0.3);
  border-radius: 4px;
  margin-top: 10px;
}

.chest-rewards text {
  display: block;
  font-size: 14px;
  color: var(--primary-color);
}

.text-warning {
  color: #ffd700 !important;
}
