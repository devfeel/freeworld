/* pages/enhance/transfer.wxss */
.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
  padding: 20rpx;
}

/* 头部 */
.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 2rpx solid rgba(255, 215, 0, 0.2);
  margin-bottom: 30rpx;
}

.back-btn {
  color: #ffd700;
  font-size: 28rpx;
  padding: 10rpx 20rpx;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #ffd700;
}

.currency {
  display: flex;
  gap: 20rpx;
}

.yuanbao {
  color: #ff6b6b;
  font-size: 28rpx;
}

/* 装备卡片 */
.item-section {
  display: flex;
  justify-content: space-around;
  align-items: center;
  margin-bottom: 40rpx;
}

.item-card {
  background: rgba(255, 255, 255, 0.05);
  border-radius: 16rpx;
  padding: 30rpx;
  width: 280rpx;
  text-align: center;
  border: 2rpx solid rgba(255, 215, 0, 0.3);
}

.item-card.target {
  border-style: dashed;
  border-color: rgba(255, 255, 255, 0.3);
}

.item-card.target.selected {
  border-style: solid;
  border-color: #4ecdc4;
}

.item-icon {
  width: 120rpx;
  height: 120rpx;
  background: rgba(0, 0, 0, 0.3);
  border-radius: 16rpx;
  margin: 0 auto 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 60rpx;
  position: relative;
  border: 4rpx solid #888;
}

.enhance-badge {
  position: absolute;
  bottom: -10rpx;
  right: -10rpx;
  background: #ff6b6b;
  color: white;
  font-size: 24rpx;
  font-weight: bold;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
}

.item-name {
  font-size: 28rpx;
  color: #fff;
  display: block;
  margin-bottom: 10rpx;
}

.item-level {
  font-size: 24rpx;
  color: #888;
}

.arrow {
  font-size: 48rpx;
  color: #ffd700;
}

.select-hint {
  color: #888;
  font-size: 24rpx;
}

/* 预览信息 */
.preview-section {
  background: rgba(255, 255, 255, 0.05);
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.preview-title {
  font-size: 28rpx;
  color: #ffd700;
  margin-bottom: 20rpx;
  display: block;
}

.preview-row {
  display: flex;
  justify-content: space-between;
  padding: 15rpx 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.1);
}

.preview-row:last-child {
  border-bottom: none;
}

.preview-label {
  color: #aaa;
  font-size: 26rpx;
}

.preview-value {
  font-size: 26rpx;
  font-weight: bold;
}

.preview-value.source {
  color: #4ecdc4;
}

.preview-value.target {
  color: #ffd700;
}

.preview-value.lost {
  color: #ff6b6b;
}

.preview-value.cost {
  color: #ff6b6b;
}

/* 卷轴信息 */
.scroll-info {
  background: rgba(255, 107, 107, 0.1);
  border: 2rpx solid rgba(255, 107, 107, 0.3);
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.scroll-icon {
  font-size: 40rpx;
}

.scroll-name {
  flex: 1;
  margin-left: 20rpx;
  color: #fff;
  font-size: 28rpx;
}

.scroll-status {
  font-size: 24rpx;
}

.scroll-status.has {
  color: #4ecdc4;
}

.scroll-status.none {
  color: #ff6b6b;
}

/* 操作按钮 */
.action-section {
  display: flex;
  gap: 20rpx;
  margin-top: 40rpx;
}

.btn {
  flex: 1;
  padding: 30rpx;
  border-radius: 16rpx;
  font-size: 30rpx;
  text-align: center;
  border: none;
}

.btn-transfer {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
}

.btn-transfer.disabled {
  opacity: 0.5;
}

.btn-back {
  background: rgba(255, 255, 255, 0.1);
  color: #aaa;
}

/* 错误提示 */
.error-section {
  background: rgba(255, 107, 107, 0.1);
  border: 2rpx solid rgba(255, 107, 107, 0.3);
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  text-align: center;
}

.error-text {
  color: #ff6b6b;
  font-size: 28rpx;
}

/* 结果弹窗 */
.result-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.8);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.result-content {
  background: #2d3748;
  border-radius: 20rpx;
  padding: 60rpx;
  text-align: center;
  min-width: 500rpx;
}

.result-content.success {
  border: 4rpx solid #4ecdc4;
}

.result-content.fail {
  border: 4rpx solid #ff6b6b;
}

.result-icon {
  font-size: 80rpx;
  display: block;
  margin-bottom: 20rpx;
}

.result-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
  display: block;
  margin-bottom: 20rpx;
}

.result-message {
  font-size: 28rpx;
  color: #aaa;
  display: block;
  margin-bottom: 40rpx;
}

.btn-confirm {
  background: #ffd700;
  color: #1a1a2e;
  padding: 20rpx 60rpx;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: bold;
}
