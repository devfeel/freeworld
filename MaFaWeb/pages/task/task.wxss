/* 任务页面样式 - 优化版 */

.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #1a1410 0%, #0d0a08 100%);
  display: flex;
  flex-direction: column;
}

/* ==================== Tab 导航 ==================== */
.tab-nav {
  display: flex;
  padding: 6px 10px;
  gap: 6px;
  background: linear-gradient(180deg, rgba(0, 0, 0, 0.4) 0%, rgba(0, 0, 0, 0.2) 100%);
  border-bottom: 1px solid rgba(212, 175, 55, 0.15);
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  gap: 3px;
  padding: 5px 2px;
  background: var(--panel-bg);
  border: 2px solid var(--border-color);
  border-radius: 4px;
  transition: all 0.2s;
}

.tab-item:active {
  transform: scale(0.98);
}

.tab-item.active {
  background: linear-gradient(135deg, rgba(212, 175, 55, 0.25) 0%, rgba(212, 175, 55, 0.08) 100%);
  border-color: rgba(212, 175, 55, 0.5);
  box-shadow: 0 2px 8px rgba(212, 175, 55, 0.2);
}

.tab-icon {
  font-size: 13px;
}

.tab-name {
  font-size: 14px;
  font-weight: bold;
  color: #888;
}

.tab-item.active .tab-name {
  color: #d4af37;
}

.tab-count {
  font-size: 11px;
  color: #666;
  background: rgba(0, 0, 0, 0.3);
  padding: 1px 5px;
  border-radius: 6px;
  margin-left: 2px;
}

.tab-item.active .tab-count {
  color: #d4af37;
  background: rgba(212, 175, 55, 0.15);
}

/* ==================== 筛选栏 ==================== */
.filter-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12px 16px;
  gap: 12px;
}

.filter-group {
  display: flex;
  gap: 8px;
  flex: 1;
}

.filter-btn {
  padding: 8px 16px;
  background: rgba(0, 0, 0, 0.3);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 20px;
  transition: all 0.2s;
}

.filter-btn text {
  font-size: 13px;
  color: #888;
}

.filter-btn.active {
  background: linear-gradient(135deg, rgba(212, 175, 55, 0.3) 0%, rgba(212, 175, 55, 0.1) 100%);
  border-color: rgba(212, 175, 55, 0.4);
}

.filter-btn.active text {
  color: #d4af37;
  font-weight: bold;
}

.refresh-action {
  display: flex;
  align-items: center;
  gap: 4px;
  padding: 8px 12px;
  background: linear-gradient(135deg, rgba(39, 174, 96, 0.2) 0%, rgba(39, 174, 96, 0.05) 100%);
  border: 1px solid rgba(39, 174, 96, 0.3);
  border-radius: 20px;
}

.refresh-icon {
  font-size: 14px;
}

.refresh-text {
  font-size: 12px;
  color: #27ae60;
  font-weight: bold;
}

/* ==================== 任务列表 ==================== */
.task-scroll {
  flex: 1;
  padding: 0 16px;
}

.task-list {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

/* 任务卡片 */
.task-card {
  display: flex;
  align-items: stretch;
  background: var(--panel-bg);
  border: 2px solid var(--border-color);
  border-radius: 4px;
  overflow: hidden;
  position: relative;
  transition: all 0.2s;
}

.task-card:active {
  transform: scale(0.99);
  border-color: var(--primary-color);
}

.task-card.completed {
  opacity: 0.7;
  background: var(--panel-bg);
}

.task-card.new {
  animation: cardGlow 2s ease-in-out infinite;
}

@keyframes cardGlow {
  0%, 100% { box-shadow: 0 0 5px rgba(212, 175, 55, 0.2); }
  50% { box-shadow: 0 0 20px rgba(212, 175, 55, 0.4); }
}

/* 左侧装饰条 */
.card-accent {
  width: 4px;
  flex-shrink: 0;
}

.card-accent.not_started {
  background: linear-gradient(180deg, #666 0%, #444 100%);
}

.card-accent.in_progress {
  background: linear-gradient(180deg, #f39c12 0%, #e74c3c 100%);
  box-shadow: 0 0 10px rgba(243, 156, 18, 0.5);
}

.card-accent.completed {
  background: linear-gradient(180deg, #27ae60 0%, #2ecc71 100%);
}

/* 任务图标 */
.task-icon-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 56px;
  flex-shrink: 0;
  position: relative;
}

.task-icon {
  font-size: 28px;
}

.priority-badge {
  position: absolute;
  top: 8px;
  right: 8px;
  width: 18px;
  height: 18px;
  background: linear-gradient(135deg, #e74c3c 0%, #c0392b 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 12px;
  font-weight: bold;
  color: #fff;
  animation: pulse 2s infinite;
}

@keyframes pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.1); }
}

/* 任务内容 */
.task-content {
  flex: 1;
  padding: 12px 8px 12px 0;
  display: flex;
  flex-direction: column;
  gap: 6px;
  min-width: 0;
}

.task-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 8px;
}

.task-name {
  font-size: 15px;
  font-weight: bold;
  color: #fff;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.task-card.completed .task-name {
  color: #888;
  text-decoration: line-through;
}

.status-tag {
  padding: 2px 8px;
  border-radius: 10px;
  font-size: 10px;
  font-weight: bold;
  flex-shrink: 0;
}

.status-tag.not_started {
  background: rgba(102, 102, 102, 0.2);
  color: #888;
}

.status-tag.in_progress {
  background: rgba(243, 156, 18, 0.2);
  color: #f39c12;
}

.status-tag.completed {
  background: rgba(39, 174, 96, 0.2);
  color: #27ae60;
}

.task-desc {
  font-size: 12px;
  color: #888;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.task-card.completed .task-desc {
  color: #666;
}

/* 进度条 */
.progress-wrap {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-top: 4px;
}

.progress-bar {
  flex: 1;
  height: 6px;
  background: rgba(0, 0, 0, 0.5);
  border-radius: 3px;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #f39c12 0%, #e74c3c 100%);
  border-radius: 3px;
  transition: width 0.5s ease;
}

.progress-text {
  font-size: 11px;
  color: #f39c12;
  font-weight: bold;
  min-width: 32px;
  text-align: right;
}

/* 奖励预览 */
.reward-preview {
  display: flex;
  gap: 12px;
  margin-top: 4px;
  flex-wrap: wrap;
}

.reward-item {
  display: flex;
  align-items: center;
  gap: 3px;
  padding: 3px 8px;
  background: rgba(0, 0, 0, 0.3);
  border-radius: 10px;
}

.reward-icon {
  font-size: 12px;
}

.reward-value {
  font-size: 11px;
  color: #d4af37;
  font-weight: bold;
}

.reward-item.title {
  background: linear-gradient(135deg, rgba(155, 89, 182, 0.2) 0%, rgba(142, 68, 173, 0.1) 100%);
  border: 1px solid rgba(155, 89, 182, 0.3);
}

.reward-item.title .reward-value {
  color: #9b59b6;
}

/* 操作按钮区域 */
.task-action {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 70px;
  flex-shrink: 0;
  border-left: 1px solid rgba(255, 255, 255, 0.05);
  padding: 12px;
}

.action-btn {
  width: 100%;
  padding: 10px 0;
  border-radius: 10px;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s;
}

.action-btn text {
  font-size: 13px;
  font-weight: bold;
  color: #fff;
}

.action-btn.primary {
  background: linear-gradient(135deg, #d4af37 0%, #b8941f 100%);
  box-shadow: 0 4px 10px rgba(212, 175, 55, 0.3);
}

.action-btn.primary:active {
  transform: scale(0.95);
  box-shadow: 0 2px 5px rgba(212, 175, 55, 0.2);
}

.action-btn.submit {
  background: linear-gradient(135deg, #3498db 0%, #2980b9 100%);
  box-shadow: 0 4px 10px rgba(52, 152, 219, 0.3);
}

.action-btn.submit:active {
  transform: scale(0.95);
}

.action-btn.disabled {
  background: rgba(102, 102, 102, 0.2);
  border: 1px solid rgba(102, 102, 102, 0.3);
}

.action-btn.disabled text {
  color: #666;
  font-size: 11px;
}

.completed-mark {
  width: 40px;
  height: 40px;
  background: linear-gradient(135deg, rgba(39, 174, 96, 0.2) 0%, rgba(39, 174, 96, 0.1) 100%);
  border: 2px solid rgba(39, 174, 96, 0.4);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.check-icon {
  font-size: 20px;
  color: #27ae60;
  font-weight: bold;
}

/* ==================== 空状态 ==================== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80px 20px;
}

.empty-icon {
  font-size: 64px;
  margin-bottom: 16px;
  opacity: 0.5;
}

.empty-title {
  font-size: 18px;
  font-weight: bold;
  color: #666;
  margin-bottom: 8px;
}

.empty-desc {
  font-size: 13px;
  color: #555;
}

.bottom-space {
  height: 30px;
}
